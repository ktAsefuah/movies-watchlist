@model WatchlistEntry
@{ ViewData["Title"] = "Remove Movie"; }

<div class="page-header">
  <div><h2>Remove Movie</h2></div>
  <a asp-controller="Home" asp-action="Index" class="btn btn-secondary btn-sm">← Dashboard</a>
</div>

<div class="form-card" style="max-width:500px;text-align:center">
  <div style="font-size:48px;margin-bottom:16px">⚠️</div>
  <p style="font-size:16px;color:var(--text);margin-bottom:8px">
    Are you sure you want to remove <strong>@Model.Movie.Title</strong> from your watchlist?
  </p>
  <p style="font-size:13px;color:var(--text3);margin-bottom:24px">This action cannot be undone.</p>

  <div style="background:var(--bg);border-radius:var(--radius-sm);padding:16px;text-align:left;margin-bottom:24px">
    <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:14px">
      <span style="color:var(--text3);font-weight:500">Title</span>
      <span>@Model.Movie.Title</span>
    </div>
    <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:14px">
      <span style="color:var(--text3);font-weight:500">Year</span>
      <span>@Model.Movie.ReleaseYear</span>
    </div>
    <div style="display:flex;justify-content:space-between;padding:7px 0;font-size:14px">
      <span style="color:var(--text3);font-weight:500">Status</span>
      <span>@Model.Status</span>
    </div>
  </div>

  <form method="post" asp-action="Delete" asp-route-id="@Model.Id">
    @Html.AntiForgeryToken()
    <div style="display:flex;gap:10px;justify-content:center">
      <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
      <button type="submit" class="btn btn-danger">Yes, Remove</button>
    </div>
  </form>
</div>
